<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvaloniaExercisesSolution.MainWindow"
        Title="Territory Game">

    <Grid RowDefinitions="Auto, *, Auto" ColumnDefinitions="70*, 30*">

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="White">
            <TextBlock x:Name="HeaderText" Text="Press Play to start" FontSize="30"
                       Foreground="Black" HorizontalAlignment="Left" Margin="30,10"/>
        </StackPanel>

        <!-- Game Board -->
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="Black" BorderThickness="3" Margin="10" Background="White">
            <Grid x:Name="GameBoard"/>
        </Border>

        <!-- Right Panel: Buttons + Scores + Leaderboard -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" Background="White">
            <StackPanel Margin="5">

                <Button Content="Play"
                        Width="80" Height="50"
                        Foreground="Black" Background="White"
                        HorizontalAlignment="Center"
                        Margin="0,10" BorderThickness="3" BorderBrush="Black"
                        Click="OnPlayClick"/>

                <Button Content="Save"
                        Width="80" Height="50"
                        Foreground="Black" Background="White"
                        HorizontalAlignment="Center"
                        Margin="0,10" BorderThickness="3" BorderBrush="Black"
                        Click="OnSaveClick"/>

                <Button Content="Load"
                        Width="80" Height="50"
                        Foreground="Black" Background="White"
                        HorizontalAlignment="Center"
                        Margin="0,10" BorderThickness="3" BorderBrush="Black"
                        Click="OnLoadClick"/>

                <Button Content="Size"
                        Width="80" Height="50"
                        Foreground="Black" Background="White"
                        HorizontalAlignment="Center"
                        Margin="0,10" BorderThickness="3" BorderBrush="Black"
                        Click="OnSizeClick"/>

                <!-- Scores Section -->
                <TextBlock Text="Scores" FontWeight="Bold" FontSize="14"
                           Foreground="Black" Margin="5,15,5,3"/>
                <StackPanel x:Name="ScoresPanel" Margin="5,0"/>

                <!-- Leaderboard Section -->
                <TextBlock Text="Leaderboard" FontWeight="Bold" FontSize="14"
                           Foreground="Black" Margin="5,15,5,3"/>
                <StackPanel x:Name="LeaderboardPanel" Margin="5,0"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="White">
            <TextBlock x:Name="FooterText" Text="6x6" FontSize="30"
                       Foreground="Black" HorizontalAlignment="Right" Margin="30,10"/>
        </StackPanel>

    </Grid>
</Window>
